# ─────────────────────────────────────────────────────────────────────────────
# CreatorClip — environment variables
# Copy to .env and fill in all values marked REQUIRED before starting the app.
# The app will exit with a clear error if any REQUIRED variable is missing.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI / LLM ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                        # REQUIRED — Anthropic API key
PREFERENCE_WEIGHT_CAP=0.5                  # max preference-model weight in the rerank blend once mature (0 below the threshold; ramps to this). Issue 60
ANTHROPIC_MODEL=claude-sonnet-4-6         # Anthropic model id fallback (single source of truth; verify vs live catalog — see docs/SKILL_FRESHNESS.md)
# Per-task model routing (Issue 318) — each key independently overridable. Defaults: Sonnet 4.6 for
# reasoning/streaming tasks; Haiku 4.5 for cheap classify tasks. Use bare aliases (no date suffix).
# Source: https://platform.claude.com/docs/en/about-claude/models/overview
ANTHROPIC_MODEL_SCORING=claude-sonnet-4-6       # clip scoring (DNA-grounded, batched)
ANTHROPIC_MODEL_DNA_BRIEF=claude-sonnet-4-6     # creator DNA brief generation
ANTHROPIC_MODEL_ANALYSIS=claude-sonnet-4-6      # per-video performance analysis
ANTHROPIC_MODEL_TITLES=claude-sonnet-4-6        # title suggestion (web_search + streaming)
ANTHROPIC_MODEL_THUMBNAILS=claude-sonnet-4-6    # thumbnail pattern analysis + concept gen
ANTHROPIC_MODEL_HOOKS=claude-haiku-4-5          # first-30s hook analysis (cheap classify)
ANTHROPIC_MODEL_CHAPTERS=claude-haiku-4-5       # chapter title generation (cheap classify)
ANTHROPIC_MODEL_PERFORMER=claude-haiku-4-5      # per-video performer analysis (cheap classify)
ANTHROPIC_MODEL_CHAT=claude-sonnet-4-6          # Pro chatbot agentic loop (streaming)
ANTHROPIC_MODEL_INTAKE=claude-sonnet-4-6        # onboarding chat intake (non-streaming)
ANTHROPIC_MODEL_IMPROVEMENT=claude-sonnet-4-6   # improvement brief (web_search + streaming)
ANTHROPIC_WEB_SEARCH_TOOL=web_search_20260209  # web_search tool version — _20260209 adds dynamic filtering (Issue 84); _20250305 still supported (no filtering). Verify via /claude-api skill.
# LLM cost constants (USD per million tokens, standard tier). Source: Anthropic pricing (fetched 2026-06-23). Override to pick up price changes without a code deploy. (Issue 220)
COST_PER_MTOK_IN_SONNET=3.0              # Sonnet 4.6 input $3/MTok standard
COST_PER_MTOK_OUT_SONNET=15.0            # Sonnet 4.6 output $15/MTok standard
COST_PER_MTOK_IN_HAIKU=1.0              # Haiku 4.5 input $1/MTok standard
COST_PER_MTOK_OUT_HAIKU=5.0             # Haiku 4.5 output $5/MTok standard
# Extended price book (Issue 289) — env-overridable; update PRICE_BOOK_VERSION whenever any rate changes.
COST_CACHE_READ_MULTIPLIER=0.1           # Anthropic cache-read multiplier (10% of base input rate). Source: platform.claude.com/docs/en/about-claude/pricing (2026-06-23)
COST_PER_MIN_DEEPGRAM=0.0043             # Deepgram Nova-2 pre-recorded $/min, pay-as-you-go. Source: deepgram.com/pricing (2026-06-23)
COST_PER_MTOK_VOYAGE=0.06                # Voyage AI voyage-3.5 $/MTok. Source: docs.voyageai.com/docs/pricing (2026-06-23)
COST_PER_GB_MO_R2=0.015                  # Cloudflare R2 standard storage $/GB/month. Source: developers.cloudflare.com/r2/pricing (2026-06-23)
COST_PER_M_R2_CLASS_A=4.50               # Cloudflare R2 Class A (PUT/DELETE) $/million ops. Source: developers.cloudflare.com/r2/pricing (2026-06-23)
COST_PER_M_R2_CLASS_B=0.36               # Cloudflare R2 Class B (GET/HEAD) $/million ops. Source: developers.cloudflare.com/r2/pricing (2026-06-23)
COST_PER_RENDER_CPU_S=0.000025           # Estimated $/CPU-second for ffmpeg render (K8s node cost estimate; tune from real billing — Issue 275 K8s staging is the linchpin)
PRICE_BOOK_VERSION=2026-06-23            # Version stamp; update whenever any vendor rate changes (FinOps Foundation cost-per-unit standard)
CHAT_DAILY_MESSAGE_LIMIT=25                # Pro chatbot: per-creator daily message cap (margin guard — Issue 152). Tune from real token logs.
CHAT_MAX_TOOL_ITERATIONS=4                # Pro chatbot: max creator-scoped tool rounds per message before a text answer is forced.
CHAT_MAX_TOKENS=1500                      # Pro chatbot: hard per-reply output ceiling.
CHAT_HISTORY_TURNS=8                      # Pro chatbot: prior turns of history sent per request (input-cost cap).
LLM_DAILY_JOB_LIMIT=50                    # Per-creator daily ceiling on LLM jobs (titles/thumbnails/insights/improvement/analysis/generate) — bounds Anthropic/Deepgram spend (Issue 228).
BRIEF_DAILY_LIMIT_PER_CREATOR=50          # Per-creator daily ceiling specifically for brief-generating endpoints (titles/thumbnails/insights-analysis/improvement). Independently tunable from LLM_DAILY_JOB_LIMIT (Issue 321).
RENDER_DAILY_JOB_LIMIT=60                 # Per-creator daily ceiling on render jobs (render/clean/submit-cuts/ingest) — bounds ffmpeg CPU + R2 egress (Issue 228).
VOYAGE_API_KEY=                           # Required unless using local embeddings

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://creatorclip:dev_password@postgres:5432/creatorclip
# REQUIRED. Use @localhost:5432 when running outside Docker. A bare `postgresql://`
# or `postgres://` DSN (e.g. injected by Render's managed Postgres connectionString)
# is auto-normalized to `postgresql+psycopg://` at load — see config._normalize_async_pg_dsn.
DATABASE_MIGRATION_URL=                   # REQUIRED in production — BYPASSRLS role for Alembic + worker cross-tenant sweeps (Issue 79). Falls back to DATABASE_URL when blank, which is dev-friendly but unsafe in prod. See docs/DEPLOYMENT.md for role setup.

# Beta event logging (Issue 151) — dedicated event_logs telemetry sink.
LOGS_DATABASE_URL=                        # Optional. Separate DB for high-volume click/request telemetry. Blank → uses DATABASE_URL (one Postgres). If set to a different DB, apply the 0025 migration there too.
EVENT_LOG_DB_ENABLED=true                 # Set false to disable DB persistence of events (they still hit the rotating app.log via observability.log_event).

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0            # Use redis://localhost:6379/0 outside Docker
# RedBeat HA Redis (Issue 263): optional. In production set to managed HA Redis endpoint
# (GCP Memorystore / Upstash). Falls back to REDIS_URL when unset (dev/test OK).
# REDBEAT_REDIS_URL=redis://YOUR_HA_REDIS_HOST:6379/0

# ── Google / YouTube OAuth ───────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=                   # REQUIRED
GOOGLE_OAUTH_CLIENT_SECRET=               # REQUIRED
OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback   # REQUIRED; update for production

# ── Security ─────────────────────────────────────────────────────────────────
# Generate TOKEN_ENCRYPTION_KEY once with: python -c "from crypto import generate_key; print(generate_key())"
TOKEN_ENCRYPTION_KEY=                     # REQUIRED — Fernet key for YouTube token columns
# KEY ROTATION: set TOKEN_ENCRYPTION_KEY_PREVIOUS to the OLD key while rotating.
# MultiFernet will try the new key first and fall back to the previous key, so
# existing tokens remain readable. Run scripts/rotate_token_key.py to re-encrypt
# all tokens under the new key, then clear this variable.
TOKEN_ENCRYPTION_KEY_PREVIOUS=            # Optional — previous Fernet key (rotation only)
JWT_SECRET_KEY=                           # REQUIRED — 32-byte random string
JWT_EXPIRY_MINUTES=60

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000
# REQUIRED. In production: lock to your exact domain. NEVER use * in production.

# ── Postgres password (used by docker-compose) ───────────────────────────────
POSTGRES_PASSWORD=dev_password

# ── Transcription ─────────────────────────────────────────────────────────────
TRANSCRIPTION_BACKEND=whisperx           # whisperx | deepgram | assemblyai
TRANSCRIPTION_TIMEOUT_S=300              # job-level upper bound per transcription (Issue 68)
TRANSCRIPTION_HTTP_TIMEOUT_S=120         # per-request socket timeout for hosted backends; keep < TRANSCRIPTION_TIMEOUT_S (Issue 76)
TRANSCRIPTION_MAX_MB=1024                # reject audio larger than this before sending to a hosted backend (Issue 76)
FFMPEG_EXTRACT_TIMEOUT_S=1800            # hard cap (s) for the ffmpeg audio-extract subprocess — kills a wedged ffmpeg (Issue A)
AUDIO_ANALYSIS_MAX_DURATION_S=14400     # truncate audio analysis at this many seconds to prevent OOM on very long files (Issue 334)
WAVEFORM_TIMEOUT_S=300                  # ffmpeg showwavespic subprocess timeout in seconds; callers scale further via duration_s kwarg (Issue 334)
WHISPER_MODEL=large-v3                   # base | small | medium | large-v3
DEEPGRAM_API_KEY=                        # Required if TRANSCRIPTION_BACKEND=deepgram
ASSEMBLYAI_API_KEY=                      # Required if TRANSCRIPTION_BACKEND=assemblyai

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local                    # local (dev) ONLY | r2 (production — REQUIRED). In ENV=production the config validator fails fast unless this is r2 + all R2_* set: app & worker have no shared media volume, so local-disk uploads are unreadable by the worker. The deploy pins this to r2.
R2_ACCOUNT_ID=                           # required in production (synced from GitHub secret on deploy)
R2_ACCESS_KEY_ID=                        # required in production (synced from GitHub secret on deploy)
R2_SECRET_ACCESS_KEY=                    # required in production (synced from GitHub secret on deploy)
R2_BUCKET=                               # required in production (synced from GitHub secret on deploy)
SOURCE_MEDIA_RETENTION_HOURS=72          # Source video purge timer
# ── Disaster-recovery backups (Issue 256) — used by scripts/backup_pg.sh on host cron ──
BACKUP_R2_BUCKET=                        # SEPARATE bucket from R2_BUCKET (e.g. creatorclip-backups). 3-2-1 rule: a media-bucket mistake must not touch backups. Apply an R2 Bucket Lock (Compliance mode, >=14d) on it.
BACKUP_ENCRYPTION_KEY=                   # age/openssl symmetric passphrase for the dump. NEVER logged/committed. Must NOT be escrowed inside the backup it protects (circular dependency). Required by backup_pg.sh at runtime.
BACKUP_RETENTION_DAILY=14                # daily dumps kept (stays <=30d for the analytics-staleness rule)
BACKUP_RETENTION_WEEKLY=8                # weekly dumps kept
YOUTUBE_ANALYTICS_MAX_STALENESS_DAYS=30  # YouTube ToS — analytics rows must be deleted within 30 days if auth cannot be re-verified. (Issue 75b / Wave-4 Fix 3; source: developers.google.com/youtube/terms/developer-policies §III.E.4.b)
EVENT_LOG_RETENTION_DAYS=90             # Issue 250 — GDPR Art. 5(1)(e): 90-day rolling purge of event_logs (behavioral telemetry). Industry-standard for SaaS event logs (60–180 days). No PII stored; defined by analytical utility. Reduce for stricter posture.
YTDLP_ENABLED=false                      # Set true only for own-channel content; never third-party
UPLOAD_MAX_MB=500                        # Max upload file size in MB
LOCAL_MEDIA_DIR=./media                  # Local storage root. Dev: relative ok (e.g. ./media). Production: MUST be absolute (e.g. /var/lib/creatorclip/media) — worker cwd is not guaranteed. (Issue 105)

# ── Engine defaults ───────────────────────────────────────────────────────────
MAX_INGESTED_TITLE_CHARS=200         # Max chars for ingested YouTube video titles. YouTube hard limit is 100 chars; 200 is a 2× safety margin that only truncates adversarially-crafted inputs (Issue 227 / OWASP LLM01).
MAX_INGESTED_DESC_CHARS=10000        # Max chars for ingested YouTube video descriptions. YouTube hard limit is 5,000 chars; 10,000 is a 2× safety margin. Descriptions are not yet stored on the Video model — this is defensive/future-proofing at the ingest boundary (Issue 227 / OWASP LLM01).
# ── Per-frame active-speaker reframe (Issue 189) ─────────────────────────────
# SAFETY: leave False until the render-env smoke test passes (requires ffmpeg +
# MediaPipe + real multi-speaker media). The legacy single-keyframe Haar crop in
# render.py remains the default until this flag is flipped. See clip_engine/reframe.py
# and docs/DECISIONS.md (2026-06-23, Issue 189) for the build-vs-buy rationale.
ACTIVE_SPEAKER_REFRAME_ENABLED=false
# Frames-per-second to sample for MediaPipe face detection in the per-frame reframe
# path. 5 fps is sufficient for talking-head content. Tune up if speaker switches
# are missed in render-env tests. Ignored when ACTIVE_SPEAKER_REFRAME_ENABLED=false.
REFRAME_SAMPLE_FPS=5.0

CLIPS_PER_VIDEO_DEFAULT=8
# Auto-render generated clips immediately after clip generation so the Review
# queue is watch-ready with no manual step. Uploading the video already consented
# to (and was charged) the minutes; rendering adds no extra spend. Set false to
# leave clips pending until the creator renders on demand.
AUTO_RENDER_CLIPS=true
# Cap on clips auto-rendered per video. 0 = all generated candidates
# (<= CLIPS_PER_VIDEO_DEFAULT); >0 renders only the top-N highest-fit immediately.
AUTO_RENDER_TOP_N=0
# ── Stream-VOD recap (Issue 190) ──────────────────────────────────────────────
# Target total-duration bounds (seconds) for a recap built from an uploaded
# past-stream VOD. MAX is the hard budget the segment selector packs against;
# MIN is the floor below which a recap is not worth rendering. Default 5-10 min.
RECAP_TARGET_DURATION_MIN_S=300
RECAP_TARGET_DURATION_MAX_S=600
MIN_VIDEOS_FOR_DNA=10
MIN_SHORTS_FOR_DNA=5
SHORTS_MAX_DURATION_S=180                  # YouTube's official Shorts max (raised from 60s in Oct 2024). Issue 87
DNA_LONGS_CAP=50                           # most-recent long-form videos considered for DNA (Issue 120)
DNA_SHORTS_CAP=75                          # most-recent Shorts considered for DNA (Issue 120)
PERSONALIZATION_THRESHOLD_LABELS=20
DECAY_HALF_LIFE_DAYS=30                     # recency half-life (days) for preference sample weights; λ=ln(2)/this. Tunable via the Issue-198 eval (grid {15,30,60,90} on held-out NDCG@5). DNA builder keeps a separate 90d half-life. Issue 200
STYLE_LEARN_THRESHOLD=5                    # Issue 187 — min occurrences of a kit-field value in the last 20 renders before a 'make it your default?' suggestion is shown. 5 matches the smart-default threshold from USPTO 10860981/NNG default-effect literature. Lower = noisier; higher = too conservative for small channels.
PREFERENCE_SCORER_CACHE_SIZE=128           # per-worker LRU of deserialized scorers, keyed by (creator,version); skips the joblib reload on rerank (Issue 78a)
PREFERENCE_MAX_TRAINING_LABELS=5000        # newest-first cap on training-feedback rows per build_and_save fit; recency decay makes older rows worth ~0 (Issue 102)
PREFERENCE_NDCG_REGRESSION_THRESHOLD=0.05  # warn-only ratchet on the per-retrain offline eval: log a warning event when a new model version's held-out NDCG@5 drops by more than this vs the previous version; never blocks the retrain (Issue 202)
LLM_TIMEOUT_SECONDS=120
YOUTUBE_QUOTA_DAILY_UNITS=8000          # Daily YouTube API budget (Google default: 10,000). Conservative default leaves 2k headroom.
YOUTUBE_QUOTA_PER_CREATOR_REFRESH_UNITS=300  # Per-creator/day sub-budget for the Beat refresh fan-out only (Issue 260). < global so interactive onboarding always has headroom; one over-budget creator's refresh is skipped, others continue.
YOUTUBE_ETAG_CACHE_TTL_S=21600          # TTL (s) for the Redis ETag/body cache on conditional Data API GETs (Issue 260). A 304 returns the cached body and spends NO quota.

# ── Stripe Billing ────────────────────────────────────────────────────────────
# Leave empty to run without billing (balance checks are skipped in dev when key is absent).
STRIPE_SECRET_KEY=                       # sk_live_... or sk_test_...
STRIPE_PUBLISHABLE_KEY=                  # pk_live_... or pk_test_... (used in pricing.html)
STRIPE_WEBHOOK_SECRET=                   # whsec_... from Stripe dashboard > Webhooks
APP_BASE_URL=http://localhost:8000       # Public base URL for Stripe redirect/cancel URLs
FREE_TRIAL_MINUTES=60                    # Minutes granted on first login (60 = ~1 hr of video)
TRIAL_DURATION_DAYS=7                    # Calendar-day trial window after first login (Issue 126)
LOW_BALANCE_THRESHOLD_MINUTES=10         # Nav chip + pre-action warning trigger (Issue 126)
LIFECYCLE_NUDGE_AFTER_DAYS=3             # Issue 246 — days after signup before the first-clip nudge fires to a creator with no videos
LIFECYCLE_INACTIVITY_DAYS=14            # Issue 246 — days of no clip-review activity before re-engagement email fires to an active creator
LIFECYCLE_FREQUENCY_CAP_HOURS=48        # Issue 246 — shared budget: at most one lifecycle email per creator per window (welcome/nudge/re-engagement)
STRIPE_TIMEOUT_S=10                      # Per-request HTTP timeout for the Stripe SDK; default ~80s would pin an executor slot under a Stripe slowdown (Issue 106)
STRIPE_RECONCILE_LOOKBACK_HOURS=48       # Issue 205 — daily reconciliation sweep looks back this many hours for paid Checkout sessions; 48h covers one missed Beat run + Stripe retry window
STRIPE_TAX_ENABLED=false                  # Issue 207 — flip to true ONLY after ≥1 active Stripe tax registration exists (Tax > Registrations). Enabling without a registration collects $0 tax (safe per Stripe docs). See docs/DECISIONS.md Issue 207.

# ── Observability (Issue 75f) ─────────────────────────────────────────────────
LOG_JSON=true                            # true = one JSON object per log line (for aggregators); false = human-readable text
LOG_LEVEL=INFO                           # Root log level. INFO logs every LLM call's token usage, each httpx request line, pipeline stages + errors — verbose & safe. DEBUG can leak request headers (incl. the API key) via httpx; use only for short local diagnosis, never standing in prod.
LOG_DIR=/app/logs                        # Directory for persistent rotating log files. Maps to ./logs on the host via .:/app Docker volume. Set to "" to disable file logging.
VERBOSE_LOGGING=false                    # Pre-prod debugging. true ⇒ full-content verbose sink (<LOG_DIR>/verbose-{app,worker}.log, or stdout when LOG_DIR=""): raw prompts/responses/transcripts, full ffmpeg commands + stderr, full task args + tracebacks for every render/LLM/transcription/chat/task op. Bypasses PII redaction. Off-prod this is the only switch needed; in production it ALSO requires VERBOSE_LOGGING_ALLOW_PROD=true. Turn off before public launch. (docs/DECISIONS.md 2026-06-29)
VERBOSE_LOGGING_ALLOW_PROD=false         # Second explicit opt-in REQUIRED to enable the verbose sink while ENV=production (the private-beta case). No effect off-prod. Keeps a routine prod deploy from leaking content unless an operator deliberately sets this too. Set false before public launch.
REQUEST_ID_HEADER=X-Request-ID           # Inbound correlation-id header; minted as UUID4 if absent. Echoed on the response.
METRICS_ENABLED=true                     # Expose Prometheus golden-signal metrics at /metrics
METRICS_TOKEN=                           # Bearer token to scrape /metrics. Optional: if unset in production, /metrics auto-disables (never exposed unauthenticated)

# ── Clip engine ───────────────────────────────────────────────────────────────
SENTENCE_BOUNDARY_MIN_PAUSE_MS=400       # Minimum silence gap (ms) treated as a sentence boundary when snapping cut points (Issue 127)
MAX_SNAP_S=3.0                           # Max seconds the engine walks from a cut point to find a sentence boundary; holds original if nothing found
# ── Filler-word + silence removal (Issue 134) ────────────────────────────────
SILENCE_REMOVAL_THRESHOLD_MS=800         # Inter-word gap above which a silence is removed by the cleaning pass
SILENCE_TAIL_MS=150                      # Breath left on each side of every silence cut — natural feel + zero-crossing for click prevention
FILLER_TIER2_FLANK_GAP_MS=150            # Tier-2 fillers (like, you know, …) are only excised when flanked by a gap >= this on at least one side
FILLER_TIER2_MAX_DURATION_MS=600         # Tier-2 fillers longer than this duration are presumed deliberate speech and skipped

# ── Security headers (Issue 229) ─────────────────────────────────────────────
# Extra CSP source expressions appended to the baseline CSP.
# E.g. for Google Fonts: "style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
# Leave empty for the strict baseline (recommended; only extend if the SPA/assets require it).
CSP_EXTRA_SOURCES=
CSRF_FETCH_METADATA_ENABLED=false         # Set true in production — checks Sec-Fetch-Site on POST/PUT/PATCH/DELETE to block cross-site requests (Issue 230). Defaults to false in dev/test (TestClient does not send Sec-Fetch-* headers)
# ── Transactional email (Issue 242) ─────────────────────────────────────────
# NOTIFY_BACKEND: 'console' logs emails (no external call — default for dev/CI);
#                 'resend'  sends via Resend API (requires RESEND_API_KEY below).
NOTIFY_BACKEND=console
# Get a Resend key at https://resend.com (3k emails/month free).
# Required when NOTIFY_BACKEND=resend. Never commit or log.
RESEND_API_KEY=                          # re_... from resend.com/api-keys
RESEND_TIMEOUT_S=10                      # seconds; mailer call timeout so DB conn is freed promptly
# Verified sender address for all outbound transactional email.
# Must match a domain verified in the Resend dashboard. Example: noreply@autoclip.studio
EMAIL_FROM=                              # e.g. noreply@autoclip.studio
# Issue 246 — CAN-SPAM physical postal address rendered in lifecycle email bodies.
# OPTIONAL (empty default — boot never fails). Doubles as the lifecycle/welcome
# SAFETY GATE: while UNSET, NO lifecycle email (welcome / nudge / re-engagement)
# is sent — the scan + send both skip and log. Set to a real, valid postal address
# to enable lifecycle email in production.
MAILING_ADDRESS=                         # e.g. CreatorClip, 123 Main St, Springfield, IL 62701, USA

# ── LLM E2E live test harness (Issue 319) ────────────────────────────────────
# Set RUN_LLM_LIVE=1 to enable live-API LLM tests (requires real ANTHROPIC_API_KEY).
# Tests marked `llm_live` are excluded from the default pytest lane (addopts in
# pytest.ini) and run ONLY when this flag is set. The nightly workflow
# (.github/workflows/llm-e2e-nightly.yml) sets this automatically.
# NEVER set to 1 in shared CI (costs real API spend on every push).
RUN_LLM_LIVE=                            # Set to "1" only for local live verification or nightly harness

# ── Live-in-isolation smoke harness (Issue 341, Lane L22) ────────────────────
# Set RUN_LIVE_SMOKE=1 to enable scripts/live_smoke.py — per-capability checks
# (db/isolation/pipeline/render/clean/title/caption/explain/publish/r2) against
# a DEPLOYED target, isolated to a synthetic `__smoke_canary__` creator.
# The harness exits 0 immediately when this is unset. `--target prod` loads
# ./.env, `--target staging` loads ./.env.staging (provide DATABASE_URL, R2_*,
# and — for --with-llm — ANTHROPIC_API_KEY there). Metered LLM checks are off
# unless --with-llm; a real YouTube upload requires --publish-live AND
# --target staging (refused on prod).
RUN_LIVE_SMOKE=                          # Set to "1" only when running the live smoke harness

# ── Clickwrap consent versions (Issue 299) ───────────────────────────────────
# Bump these ISO-8601 date strings whenever a material change is published to
# /static/tos.html or /static/privacy.html.  Recorded on each creator's row at
# first sign-in so a future re-prompt path can detect version mismatches.
TOS_VERSION=2026-06-23
PRIVACY_VERSION=2026-06-23

# ── Error tracking — Sentry / GlitchTip (Issue 281) ─────────────────────────
# Leave empty to disable error tracking (default in dev/CI). In production set to
# your Sentry project DSN (e.g. https://xxx@sentry.io/123) or a GlitchTip DSN
# (drop-in compatible). Never commit a live DSN.
SENTRY_DSN=                              # Optional — empty disables the SDK
SENTRY_ENVIRONMENT=                      # Optional — defaults to ENV if unset
# IMAGE_SHA is set at container build time from the git SHA (Dockerfile GIT_SHA build-arg).
# When set, Sentry tags every event with the exact build that produced it.
IMAGE_SHA=                               # Optional — set at image build time (e.g. git rev-parse --short HEAD)

# ── OpenTelemetry / Grafana Cloud (Issue 326) ────────────────────────────────
# All OTEL_* settings are optional. Leave OTEL_EXPORTER_OTLP_ENDPOINT empty
# (the default) to disable the entire OTel SDK — no imports, no network calls.
# See docs/RENDER_DEPLOY.md §12 for Grafana Cloud setup.
#
# Grafana Cloud OTLP gateway URL (find it in Grafana Cloud → My Account → OTLP).
# Example: https://otlp-gateway-prod-us-east-0.grafana.net/otlp
OTEL_EXPORTER_OTLP_ENDPOINT=            # Optional — empty disables all OTel telemetry
# Grafana Cloud Basic-auth header. Format: "Authorization=Basic <base64(instanceID:token)>"
# Never commit. Treat as a secret (same class as API keys).
OTEL_EXPORTER_OTLP_HEADERS=            # Optional — Grafana Cloud auth token (secret)
# Resource service.name tag (overridden per-process: web="creatorclip-web", worker="creatorclip-worker")
OTEL_SERVICE_NAME=creatorclip           # Default — rarely needs to change
# Head-based trace sampling rate [0.0, 1.0]. 1.0 = capture all traces (correct for beta scale).
OTEL_TRACES_SAMPLE_RATE=1.0             # Optional — default 1.0
# Push golden-signal metrics via OTLP to Grafana Cloud (in addition to /metrics Prometheus endpoint).
OTEL_METRICS_ENABLED=true              # Optional — default true
# Attach an OTel LoggingHandler for in-process log shipping (default OFF).
# Prefer a Render syslog drain for logs (zero code, see docs/RENDER_DEPLOY.md §12).
OTEL_LOGS_ENABLED=false                # Optional — default false

# ── Environment ───────────────────────────────────────────────────────────────
ENV=development                          # development | staging | production (any other value fails at boot)
# In production: set ENV=production (disables /docs, tightens error messages)
STATIC_VERSION=dev                       # CSS/JS cache-bust query string; set to short git SHA at image build time (see Dockerfile GIT_SHA build-arg)

# ── Deploy / Cloudflare Tunnel ────────────────────────────────────────────────
# Required in production (docker-compose.prod.yml cloudflared service). Routes
# https://autoclip.studio → app:8000 with no open inbound ports. Get the token
# from Cloudflare → Zero Trust → Networks → Tunnels → your tunnel → Install connector.
CLOUDFLARE_TUNNEL_TOKEN=
