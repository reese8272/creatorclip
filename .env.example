# ─────────────────────────────────────────────────────────────────────────────
# CreatorClip — environment variables
# Copy to .env and fill in all values marked REQUIRED before starting the app.
# The app will exit with a clear error if any REQUIRED variable is missing.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI / LLM ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                        # REQUIRED — Anthropic API key
VOYAGE_API_KEY=                           # Required unless using local embeddings

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://creatorclip:dev_password@postgres:5432/creatorclip
# REQUIRED. Use @localhost:5432 when running outside Docker.

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0            # Use redis://localhost:6379/0 outside Docker

# ── Google / YouTube OAuth ───────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=                   # REQUIRED
GOOGLE_OAUTH_CLIENT_SECRET=               # REQUIRED
OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback   # REQUIRED; update for production

# ── Security ─────────────────────────────────────────────────────────────────
# Generate TOKEN_ENCRYPTION_KEY once with: python -c "from crypto import generate_key; print(generate_key())"
TOKEN_ENCRYPTION_KEY=                     # REQUIRED — Fernet key for YouTube token columns
JWT_SECRET_KEY=                           # REQUIRED — 32-byte random string
JWT_EXPIRY_MINUTES=60

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000
# REQUIRED. In production: lock to your exact domain. NEVER use * in production.

# ── Postgres password (used by docker-compose) ───────────────────────────────
POSTGRES_PASSWORD=dev_password

# ── Transcription ─────────────────────────────────────────────────────────────
TRANSCRIPTION_BACKEND=whisperx           # whisperx | deepgram | assemblyai
WHISPER_MODEL=large-v3                   # base | small | medium | large-v3
DEEPGRAM_API_KEY=                        # Required if TRANSCRIPTION_BACKEND=deepgram
ASSEMBLYAI_API_KEY=                      # Required if TRANSCRIPTION_BACKEND=assemblyai

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local                    # local (dev) | r2 (production)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
SOURCE_MEDIA_RETENTION_HOURS=72          # Source video purge timer
YTDLP_ENABLED=false                      # Set true only for own-channel content; never third-party
UPLOAD_MAX_MB=500                        # Max upload file size in MB
LOCAL_MEDIA_DIR=./media                  # Local storage root (dev only)

# ── Engine defaults ───────────────────────────────────────────────────────────
CLIPS_PER_VIDEO_DEFAULT=8
MIN_VIDEOS_FOR_DNA=10
MIN_SHORTS_FOR_DNA=5
PERSONALIZATION_THRESHOLD_LABELS=20
LLM_TIMEOUT_SECONDS=120
YOUTUBE_QUOTA_DAILY_UNITS=8000          # Daily YouTube API budget (Google default: 10,000). Conservative default leaves 2k headroom.

# ── Environment ───────────────────────────────────────────────────────────────
ENV=development                          # development | production
# In production: set ENV=production (disables /docs, tightens error messages)
