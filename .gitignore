# Secrets — never commit these
.env
.env.local
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/
pip-wheel-metadata/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# Docker volumes (if bound locally)
postgres_data/

# Redis snapshot (created when running redis-server locally for tests)
*.rdb

# Local media / clip output
local_storage/
*.mp4
*.webm
*.m4a

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
"Screenshot 2026-05-27 124552.png"

# Claude Code per-project state (worktrees, agent caches, session metadata)
# — ignore everything EXCEPT committed project skills and slash commands.
.claude/*
!.claude/skills/
!.claude/commands/

# Assessment artifacts that are regenerated each run (the register/report and
# baselines ARE committed; these machine outputs are not).
docs/assessment/_machine.json
docs/assessment/_coverage.xml

# tests/perf runtime artifacts
tests/perf/.env.perf
tests/perf/perf_results*.csv
